<Window x:Class="ObsidianX.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ae="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="ObsidianX — Neural Knowledge Engine"
        Width="1400" Height="900" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing" Storyboard.TargetProperty="Opacity"
                             From="0.8" To="0.2" Duration="0:0:2" AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="RotateBrain" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="BrainRotation" Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:30"/>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="16" Background="{StaticResource DeepSpaceBrush}"
            BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1">
        <Grid>
            <!-- Background ambient glow -->
            <Ellipse Width="600" Height="600" HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-200,-200,0" Opacity="0.03">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-100,0,0,-100" Opacity="0.04">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{StaticResource NeonCyanColor}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                            <Border Width="24" Height="24" CornerRadius="6" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="{StaticResource NeonCyanColor}" Offset="0"/>
                                        <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="X" FontWeight="Black" FontSize="14" Foreground="#0B0B1A"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ObsidianX" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" — Neural Knowledge Engine" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                                       Margin="4,2,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                            <Button Content="—" Click="Minimize_Click" Width="36" Height="28"
                                    Style="{StaticResource NavButton}" FontSize="12"/>
                            <Button Content="□" Click="Maximize_Click" Width="36" Height="28"
                                    Style="{StaticResource NavButton}" FontSize="12"/>
                            <Button Content="✕" Click="Close_Click" Width="36" Height="28"
                                    FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Width="36" Height="28">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MAIN CONTENT -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDEBAR -->
                    <Border Grid.Column="0" Background="{StaticResource SidebarGradient}"
                            BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Brain Identity -->
                            <Border Grid.Row="0" Margin="12,12,12,8" Padding="14" CornerRadius="10"
                                    Background="{StaticResource SurfaceBrush}">
                                <StackPanel>
                                    <Grid HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Ellipse x:Name="PulseRing" Width="56" Height="56" Opacity="0.5"
                                                 StrokeThickness="2" Stroke="{StaticResource NeonCyanBrush}"/>
                                        <Ellipse Width="48" Height="48">
                                            <Ellipse.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="{StaticResource NeonCyanColor}" Offset="0"/>
                                                    <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="&#x1F9E0;" FontSize="22" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock x:Name="BrainNameText" Text="My Brain" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="BrainAddressText" Text="0xBRAIN-..." FontSize="9"
                                               FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource NeonCyanBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"
                                               Cursor="Hand" MouseLeftButtonDown="CopyAddress_Click"
                                               ToolTip="Click to copy address"/>
                                </StackPanel>
                            </Border>

                            <!-- Nav -->
                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <TextBlock Text="NAVIGATION" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="22,8,0,12" FontWeight="SemiBold"/>
                                <Button x:Name="NavDashboard" Content="&#x2B21;  Dashboard"
                                        Style="{StaticResource NavButtonActive}" Click="Nav_Click" Tag="Dashboard"/>
                                <Button x:Name="NavBrainGraph" Content="&#x25C9;  Brain Graph"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="BrainGraph"/>
                                <Button x:Name="NavNetwork" Content="&#x2B22;  Network"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Network"/>
                                <Button x:Name="NavEditor" Content="&#x270F;  Editor"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Editor"/>
                                <Button x:Name="NavVault" Content="&#x1F4C1;  Vault Explorer"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Vault"/>
                                <Button x:Name="NavSearch" Content="&#x1F50D;  Search"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Search"/>
                                <Button x:Name="NavClaude" Content="&#x1F916;  Claude AI"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Claude"/>

                                <Button x:Name="NavGrowth" Content="&#x1F4C8;  Growth"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Growth"/>

                                <TextBlock Text="NETWORK" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="22,24,0,12" FontWeight="SemiBold"/>
                                <Button x:Name="NavPeers" Content="&#x1F465;  Peers"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Peers"/>
                                <Button x:Name="NavSharing" Content="&#x1F504;  Sharing"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Sharing"/>

                                <TextBlock Text="SYSTEM" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                           Margin="22,24,0,12" FontWeight="SemiBold"/>
                                <Button x:Name="NavSettings" Content="&#x2699;  Settings"
                                        Style="{StaticResource NavButton}" Click="Nav_Click" Tag="Settings"/>
                            </StackPanel>

                            <!-- Network Status -->
                            <Border Grid.Row="2" Margin="12,0,12,12" Padding="12" CornerRadius="8"
                                    Background="{StaticResource SurfaceBrush}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="NetworkDot" Width="8" Height="8" Fill="{StaticResource TextMutedBrush}"
                                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="NetworkStatusText" Text="Offline" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="PeerCountText" Text="0 peers connected" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="16,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- CONTENT AREA -->
                    <Grid Grid.Column="1">
                        <!-- Dashboard -->
                        <Grid x:Name="DashboardView" Visibility="Visible">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                                <StackPanel>
                                    <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Your neural knowledge overview" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

                                    <!-- Stats -->
                                    <UniformGrid Columns="4" Margin="0,0,0,20">
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock x:Name="StatNotes" Text="0" Style="{StaticResource StatNumber}"
                                                           Foreground="{StaticResource NeonCyanBrush}"/>
                                                <TextBlock Text="KNOWLEDGE NODES" Style="{StaticResource StatLabel}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardPanel}" Margin="4,0,4,0">
                                            <StackPanel>
                                                <TextBlock x:Name="StatWords" Text="0" Style="{StaticResource StatNumber}"
                                                           Foreground="{StaticResource ElectricPurpleBrush}"/>
                                                <TextBlock Text="TOTAL WORDS" Style="{StaticResource StatLabel}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardPanel}" Margin="4,0,4,0">
                                            <StackPanel>
                                                <TextBlock x:Name="StatLinks" Text="0" Style="{StaticResource StatNumber}"
                                                           Foreground="{StaticResource NeonPinkBrush}"/>
                                                <TextBlock Text="CONNECTIONS" Style="{StaticResource StatLabel}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource CardPanel}" Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock x:Name="StatCategories" Text="0" Style="{StaticResource StatNumber}"
                                                           Foreground="{StaticResource NeonGreenBrush}"/>
                                                <TextBlock Text="EXPERTISE AREAS" Style="{StaticResource StatLabel}"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <!-- 3D Brain + Expertise -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="360"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,12,0" MinHeight="380">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <TextBlock Text="NEURAL KNOWLEDGE MAP" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextMutedBrush}"/>
                                                    <TextBlock Text="Drag=rotate | Scroll=zoom | Click=info | Right-click=kick"
                                                               FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                                               HorizontalAlignment="Right" Opacity="0.6"/>
                                                </Grid>

                                                <!-- Transparent Border catches ALL mouse events including empty space -->
                                                <Border Grid.Row="1" Margin="0,8,0,0" Background="Transparent"
                                                        MouseLeftButtonDown="Viewport_MouseDown"
                                                        MouseLeftButtonUp="Viewport_MouseUp"
                                                        MouseMove="Viewport_MouseMove"
                                                        MouseWheel="Viewport_MouseWheel"
                                                        MouseRightButtonDown="Viewport_RightClick">
                                                <Viewport3D x:Name="BrainViewport" ClipToBounds="True"
                                                            IsHitTestVisible="False">
                                                    <Viewport3D.Camera>
                                                        <PerspectiveCamera x:Name="DashCam" Position="0,2,10"
                                                                           LookDirection="0,-0.2,-1"
                                                                           UpDirection="0,1,0" FieldOfView="45"/>
                                                    </Viewport3D.Camera>
                                                    <ModelVisual3D>
                                                        <ModelVisual3D.Content>
                                                            <AmbientLight Color="#333355"/>
                                                        </ModelVisual3D.Content>
                                                    </ModelVisual3D>
                                                    <ModelVisual3D>
                                                        <ModelVisual3D.Content>
                                                            <DirectionalLight Color="#00F0FF" Direction="-1,-1,-1"/>
                                                        </ModelVisual3D.Content>
                                                    </ModelVisual3D>
                                                    <ModelVisual3D>
                                                        <ModelVisual3D.Content>
                                                            <DirectionalLight Color="#8B5CF6" Direction="1,0.5,-0.5"/>
                                                        </ModelVisual3D.Content>
                                                    </ModelVisual3D>
                                                    <ModelVisual3D x:Name="BrainModel"/>
                                                </Viewport3D>
                                                </Border>

                                                <!-- Node Info Panel (shows on click) -->
                                                <Border x:Name="NodeInfoPanel" Grid.Row="2" Visibility="Collapsed"
                                                        Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                                        Padding="14,10" Margin="0,8,0,0" MaxHeight="200"
                                                        BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Ellipse x:Name="NodeInfoDot" Width="10" Height="10"
                                                                     Fill="{StaticResource NeonCyanBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <TextBlock x:Name="NodeInfoTitle" Text="" FontSize="13"
                                                                           FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                                <TextBlock x:Name="NodeInfoDetail" Text="" FontSize="10"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                <Button Content="&#x26A1; Kick" Style="{StaticResource NeonButton}"
                                                                        Padding="10,4" FontSize="11" Click="KickNode_Click" Margin="0,0,4,0"/>
                                                                <Button Content="&#x1F4D6; Open" Style="{StaticResource NeonButtonFilled}"
                                                                        Padding="10,4" FontSize="11" Click="OpenDashNodeFile_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <!-- Content Preview -->
                                                        <ScrollViewer Grid.Row="1" MaxHeight="120" Margin="0,8,0,0"
                                                                      VerticalScrollBarVisibility="Auto">
                                                            <TextBlock x:Name="NodeInfoContent" Text="" FontSize="11"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                                       TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                            <StackPanel>
                                                <TextBlock Text="EXPERTISE PROFILE" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,16"/>
                                                <StackPanel x:Name="ExpertisePanel"/>
                                                <Border Margin="0,20,0,0" Padding="12" CornerRadius="8"
                                                        Background="{StaticResource SurfaceBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="BRAIN ADDRESS" FontSize="10"
                                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                        <TextBlock x:Name="FullAddressText" Text="0xBRAIN-..."
                                                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                                                   Foreground="{StaticResource NeonCyanBrush}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="VAULT PATH" FontSize="10"
                                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,6"/>
                                                        <TextBlock x:Name="VaultPathText" Text="..."
                                                                   FontSize="11" FontFamily="{StaticResource MonoFont}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Claude Connection -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="CLAUDE AI CONNECTION" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock x:Name="ClaudeStatusText" Text="Checking connection..."
                                                           FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock x:Name="ClaudeDetailText" Text="" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Connect to Claude"
                                                    Style="{StaticResource NeonButtonFilled}"
                                                    Click="ConnectClaude_Click" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Quick Actions -->
                                    <Border Style="{StaticResource CardPanel}">
                                        <StackPanel>
                                            <TextBlock Text="QUICK ACTIONS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                            <WrapPanel>
                                                <Button Content="&#x1F504; Re-index Vault" Style="{StaticResource NeonButton}"
                                                        Click="ReindexVault_Click" Margin="0,0,8,8"/>
                                                <Button Content="&#x1F4D6; Open in Obsidian" Style="{StaticResource NeonButton}"
                                                        Click="OpenObsidian_Click" Margin="0,0,8,8"/>
                                                <Button Content="&#x1F310; Join Network" Style="{StaticResource NeonButton}"
                                                        Click="JoinNetwork_Click" Margin="0,0,8,8"/>
                                                <Button Content="&#x1F4CA; Export Stats" Style="{StaticResource NeonButton}"
                                                        Click="ExportStats_Click" Margin="0,0,8,8"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- Brain Graph View -->
                        <Grid x:Name="BrainGraphView" Visibility="Collapsed">
                            <Border Style="{StaticResource CardPanel}" Margin="24,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="BRAIN GRAPH" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBlock x:Name="GraphFPS" Text="" FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="12,0,0,0"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="&#x1F4A5; Shake" Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10" Click="ShakeGraph_Click" Margin="0,0,6,0"/>
                                            <Button Content="&#x1F504; Reset" Style="{StaticResource NeonButton}"
                                                    Padding="10,3" FontSize="10" Click="ResetCamera_Click"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Transparent border catches mouse on empty space -->
                                    <Border Grid.Row="1" Background="Transparent"
                                            MouseLeftButtonDown="FullGraph_MouseDown"
                                            MouseLeftButtonUp="FullGraph_MouseUp"
                                            MouseMove="FullGraph_MouseMove"
                                            MouseWheel="FullGraph_MouseWheel"
                                            MouseRightButtonDown="FullGraph_RightClick">
                                    <Viewport3D x:Name="FullGraphViewport" ClipToBounds="True"
                                                IsHitTestVisible="False">
                                        <Viewport3D.Camera>
                                            <PerspectiveCamera x:Name="GraphCam" Position="0,3,14"
                                                               LookDirection="0,-0.2,-1"
                                                               UpDirection="0,1,0" FieldOfView="50"/>
                                        </Viewport3D.Camera>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><AmbientLight Color="#444466"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><DirectionalLight Color="#00F0FF" Direction="-1,-1,-1"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D>
                                            <ModelVisual3D.Content><DirectionalLight Color="#FF006E" Direction="1,1,-0.5"/></ModelVisual3D.Content>
                                        </ModelVisual3D>
                                        <ModelVisual3D x:Name="FullGraphModel"/>
                                    </Viewport3D>
                                    </Border>

                                    <!-- Selected Node Info with Content Preview -->
                                    <Border x:Name="GraphNodeInfo" Grid.Row="2" Visibility="Collapsed"
                                            Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                            Padding="14,10" Margin="0,8,0,0" MaxHeight="220"
                                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse x:Name="GraphNodeDot" Width="12" Height="12"
                                                         Fill="{StaticResource NeonCyanBrush}"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock x:Name="GraphNodeTitle" Text="" FontSize="14"
                                                               FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock x:Name="GraphNodeMeta" Text="" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Button Content="&#x26A1; Kick" Style="{StaticResource NeonButton}"
                                                            Padding="10,4" FontSize="11" Click="KickGraphNode_Click" Margin="0,0,6,0"/>
                                                    <Button Content="&#x1F4D6; Open" Style="{StaticResource NeonButtonFilled}"
                                                            Padding="10,4" FontSize="11" Click="OpenNodeFile_Click"/>
                                                </StackPanel>
                                            </Grid>
                                            <ScrollViewer Grid.Row="1" MaxHeight="140" Margin="0,8,0,0"
                                                          VerticalScrollBarVisibility="Auto">
                                                <TextBlock x:Name="GraphNodeContent" Text="" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"/>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Network View -->
                        <Grid x:Name="NetworkView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Network — ObsidianX Brain Mesh" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Connect your brain to the collective knowledge network"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,12,0">
                                        <StackPanel>
                                            <TextBlock Text="NETWORK STATUS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,20"/>
                                            <Border HorizontalAlignment="Center" Width="200" Height="200" CornerRadius="100"
                                                    Margin="0,20" BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="2">
                                                <Grid>
                                                    <Ellipse Width="160" Height="160" Opacity="0.1">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="0"/>
                                                                <GradientStop Color="Transparent" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="NetworkPeerCount" Text="0" FontSize="42"
                                                                   FontWeight="Bold" Foreground="{StaticResource ElectricPurpleBrush}"
                                                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}"/>
                                                        <TextBlock Text="ACTIVE PEERS" FontSize="10"
                                                                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <Button x:Name="JoinNetworkBtn" Content="&#x1F310; Join ObsidianX Network"
                                                    Click="JoinNetwork_Click"
                                                    Style="{StaticResource NeonButtonFilled}" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                            <Button x:Name="LeaveNetworkBtn" Content="Disconnect"
                                                    Click="LeaveNetwork_Click" Visibility="Collapsed"
                                                    Style="{StaticResource NeonButton}" HorizontalAlignment="Center" Margin="0,8,0,0"
                                                    Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardPanel}">
                                        <StackPanel>
                                            <TextBlock Text="FIND EXPERT BRAINS" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                            <TextBlock Text="Search Category" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="MatchCategoryCombo" Margin="0,0,0,12"
                                                      Background="{StaticResource SurfaceBrush}"
                                                      Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <Button Content="&#x1F50E; Find Experts" Click="FindExperts_Click"
                                                    Style="{StaticResource NeonButtonFilled}" Margin="0,0,0,16"/>
                                            <TextBlock Text="RESULTS" FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                                       Margin="0,0,0,8"/>
                                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="MatchResultsList">
                                                    <TextBlock Text="Connect to network first" FontSize="11"
                                                               Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- Claude AI View -->
                        <Grid x:Name="ClaudeView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Claude AI — Brain Assistant" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ClaudeViewStatus" Text="Checking..." FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="ClaudeOutput" TextWrapping="Wrap" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="Welcome to ObsidianX + Claude AI.&#x0A;&#x0A;Your vault is Claude's 'second brain'. Type below to ask Claude about your knowledge..."/>
                                    </ScrollViewer>
                                </Border>
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ClaudeInput" Style="{StaticResource NeonTextBox}"
                                             KeyDown="ClaudeInput_KeyDown" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Ask Claude" Style="{StaticResource NeonButtonFilled}"
                                            Click="AskClaude_Click"/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- Vault Explorer -->
                        <Grid x:Name="VaultView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Vault Explorer" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="New Note" Style="{StaticResource NeonButtonFilled}"
                                            Click="VaultNewNote_Click" Padding="12,6" Margin="0,0,8,0" FontSize="11"/>
                                    <Button Content="New Folder" Style="{StaticResource NeonButton}"
                                            Click="VaultNewFolder_Click" Padding="12,6" Margin="0,0,8,0" FontSize="11"/>
                                    <Button Content="Refresh" Style="{StaticResource NavButton}"
                                            Click="VaultRefresh_Click" Padding="12,6" FontSize="11"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                                    <TreeView x:Name="VaultTree" Background="Transparent"
                                              Foreground="{StaticResource TextPrimaryBrush}" BorderThickness="0"
                                              MouseDoubleClick="VaultTree_DoubleClick">
                                        <TreeView.ContextMenu>
                                            <ContextMenu Background="{StaticResource DarkPanelBrush}"
                                                         Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource SurfaceLightBrush}">
                                                <MenuItem Header="Open in Editor" Click="VaultOpenInEditor_Click"/>
                                                <MenuItem Header="Rename" Click="VaultRename_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Delete" Click="VaultDelete_Click" Foreground="#FF4444"/>
                                            </ContextMenu>
                                        </TreeView.ContextMenu>
                                    </TreeView>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ PEERS VIEW ═══ -->
                        <Grid x:Name="PeersView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Connected Peers" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="PeersSubtitle" Text="Join the network to see peers"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button Content="&#x1F504; Refresh" Style="{StaticResource NeonButton}"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Click="RefreshPeers_Click" Padding="12,6" FontSize="11"/>
                                </Grid>
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="PeersList"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ SHARING VIEW ═══ -->
                        <Grid x:Name="SharingView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Knowledge Sharing" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Share and receive knowledge with peers on the network"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <!-- Incoming Requests -->
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="INCOMING REQUESTS" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource NeonPinkBrush}" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="IncomingSharesList">
                                            <TextBlock Text="No incoming requests" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Share History -->
                                <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                                    <StackPanel>
                                        <TextBlock Text="SHARING HISTORY" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                                        <StackPanel x:Name="ShareHistoryList">
                                            <TextBlock Text="No sharing history yet" FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ GROWTH CHART VIEW ═══ -->
                        <Grid x:Name="GrowthView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Knowledge Growth" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Track your brain's expertise growth across domains"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Border Grid.Row="1" Style="{StaticResource CardPanel}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Bar chart drawn in code-behind -->
                                        <Canvas x:Name="GrowthCanvas" Grid.Row="0" Margin="0,0,0,12"/>
                                        <StackPanel x:Name="GrowthLegend" Grid.Row="1" Orientation="Horizontal"
                                                    HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ EDITOR VIEW ═══ -->
                        <Grid x:Name="EditorView" Visibility="Collapsed">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Editor toolbar -->
                                <Border Grid.Row="0" Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,0,0,1"
                                        Padding="8,4">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock x:Name="EditorFileTitle" Text="No file open" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="{StaticResource NeonCyanBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock x:Name="EditorDirtyIndicator" Text="" FontSize="13"
                                                       FontWeight="Bold" Foreground="{StaticResource NeonPinkBrush}"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="New" Style="{StaticResource NavButton}" Click="EditorNew_Click"
                                                    Padding="10,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="H1" Style="{StaticResource NavButton}" Click="EditorH1_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="H2" Style="{StaticResource NavButton}" Click="EditorH2_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="B" Style="{StaticResource NavButton}" Click="EditorBold_Click"
                                                    Padding="8,4" FontSize="11" FontWeight="Bold" Margin="2,0"/>
                                            <Button Content="I" Style="{StaticResource NavButton}" Click="EditorItalic_Click"
                                                    Padding="8,4" FontSize="11" FontStyle="Italic" Margin="2,0"/>
                                            <Button Content="[[]]" Style="{StaticResource NavButton}" Click="EditorLink_Click"
                                                    Padding="8,4" FontSize="11" Foreground="{StaticResource NeonCyanBrush}" Margin="2,0"/>
                                            <Button Content="`code`" Style="{StaticResource NavButton}" Click="EditorCode_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                            <Button Content="[ ]" Style="{StaticResource NavButton}" Click="EditorTask_Click"
                                                    Padding="8,4" FontSize="11" Margin="2,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Split: Editor + Preview -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Code editor -->
                                    <ae:TextEditor x:Name="MarkdownEditorControl" Grid.Column="0"
                                                   FontFamily="JetBrains Mono, Cascadia Code, Consolas"
                                                   FontSize="14" ShowLineNumbers="True" WordWrap="True"
                                                   Background="{StaticResource DeepSpaceBrush}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Padding="8"/>

                                    <!-- Splitter -->
                                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                                  Background="{StaticResource SurfaceLightBrush}" Cursor="SizeWE"/>

                                    <!-- Preview -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{StaticResource DeepSpaceBrush}"
                                                BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1,0,0,0">
                                            <FlowDocumentScrollViewer x:Name="MarkdownPreview"
                                                                       VerticalScrollBarVisibility="Auto"
                                                                       IsToolBarVisible="False"/>
                                        </Border>

                                        <!-- Backlinks panel -->
                                        <Border Grid.Row="1" Background="{StaticResource DarkPanelBrush}"
                                                BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="1,1,0,0"
                                                MaxHeight="160">
                                            <StackPanel Margin="12,8">
                                                <TextBlock Text="BACKLINKS" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                                                <ScrollViewer MaxHeight="110" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel x:Name="BacklinksPanel"/>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>

                                <!-- Editor status bar -->
                                <Border Grid.Row="2" Background="{StaticResource DarkPanelBrush}"
                                        BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,1,0,0"
                                        Padding="12,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="EditorCursorPos" Text="Ln 1, Col 1" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                                        <TextBlock x:Name="EditorWordCount" Text="0 words" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,16,0"/>
                                        <TextBlock Text="Ctrl+S Save | Ctrl+B Bold | Ctrl+I Italic | Ctrl+K WikiLink | Ctrl+F Search"
                                                   FontSize="10" Foreground="{StaticResource TextMutedBrush}" Opacity="0.5"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <!-- ═══ SEARCH VIEW ═══ -->
                        <Grid x:Name="SearchView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Search Vault" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Full-text search across all notes"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <Grid Grid.Row="1" Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="SearchBox" Style="{StaticResource NeonTextBox}"
                                             FontSize="14" Padding="12,8" KeyDown="SearchBox_KeyDown"
                                             Tag="Search notes... (Enter to search)"/>
                                    <Button Grid.Column="1" Content="Search" Style="{StaticResource NeonButtonFilled}"
                                            Padding="20,8" Margin="8,0,0,0" Click="SearchExecute_Click"/>
                                </Grid>
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="SearchResults"/>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <!-- ═══ SETTINGS VIEW ═══ -->
                        <Grid x:Name="SettingsView" Visibility="Collapsed">
                            <Grid Margin="24,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Configure your ObsidianX brain"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <!-- Brain Identity -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="BRAIN IDENTITY" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                                <TextBlock Text="Display Name" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsBrainName" Style="{StaticResource NeonTextBox}"
                                                         Margin="0,0,0,12"/>
                                                <TextBlock Text="Brain Address (read-only)" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsBrainAddress" Style="{StaticResource NeonTextBox}"
                                                         IsReadOnly="True" Opacity="0.6" Margin="0,0,0,12"/>
                                                <Button Content="Save Name" Style="{StaticResource NeonButtonFilled}"
                                                        Click="SaveBrainName_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Vault Path -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="VAULT CONFIGURATION" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                                <TextBlock Text="Vault Path" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsVaultPath" Style="{StaticResource NeonTextBox}"
                                                         IsReadOnly="True" Opacity="0.6" Margin="0,0,0,12"/>
                                                <Button Content="Change Vault Path" Style="{StaticResource NeonButton}"
                                                        Click="ChangeVaultPath_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Network -->
                                        <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="NETWORK" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                                                <TextBlock Text="Server URL" FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBox x:Name="SettingsServerUrl" Style="{StaticResource NeonTextBox}"
                                                         Text="http://localhost:5142/brain-hub" Margin="0,0,0,12"/>
                                                <Button Content="Save Server URL" Style="{StaticResource NeonButtonFilled}"
                                                        Click="SaveServerUrl_Click" HorizontalAlignment="Left" Padding="16,8"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- About -->
                                        <Border Style="{StaticResource CardPanel}">
                                            <StackPanel>
                                                <TextBlock Text="ABOUT" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="ObsidianX — Neural Knowledge Engine v1.0.0"
                                                           FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="Decentralized brain-to-brain knowledge sharing"
                                                           FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- QUICK SWITCHER OVERLAY (Ctrl+O) -->
                <Grid x:Name="QuickSwitcherOverlay" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="999">
                    <Border Background="#80000000" MouseLeftButtonDown="QuickSwitcher_Close"/>
                    <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,60,0,0"
                            Width="500" MaxHeight="400"
                            Background="{StaticResource DarkPanelBrush}"
                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="0">
                        <Border.Effect>
                            <DropShadowEffect Color="{StaticResource NeonCyanColor}" BlurRadius="30" Opacity="0.3" ShadowDepth="0"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="QuickSwitcherInput" Grid.Row="0"
                                     FontSize="16" Padding="16,12" Background="Transparent"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderThickness="0,0,0,1" BorderBrush="{StaticResource SurfaceLightBrush}"
                                     FontFamily="{StaticResource MonoFont}"
                                     TextChanged="QuickSwitcher_TextChanged" KeyDown="QuickSwitcher_KeyDown"/>
                            <ScrollViewer Grid.Row="1" MaxHeight="320" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="QuickSwitcherResults"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- STATUS BAR -->
                <Border Grid.Row="2" Background="{StaticResource DarkPanelBrush}"
                        BorderBrush="{StaticResource SurfaceLightBrush}" BorderThickness="0,1,0,0">
                    <Grid Margin="16,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="{StaticResource NeonGreenBrush}" Margin="0,0,6,0"/>
                            <TextBlock x:Name="StatusText" Text="Ready" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="VersionText" Text="ObsidianX v1.0.0" FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
