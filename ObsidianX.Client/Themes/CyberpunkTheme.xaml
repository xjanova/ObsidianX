<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- ObsidianX Cyberpunk Theme — Deep Space + Neon Glow -->
    <!-- ═══════════════════════════════════════════════════ -->

    <!-- Color Palette -->
    <Color x:Key="DeepSpaceColor">#FF0B0B1A</Color>
    <Color x:Key="DarkPanelColor">#FF12122A</Color>
    <Color x:Key="SurfaceColor">#FF1A1A2E</Color>
    <Color x:Key="SurfaceLightColor">#FF252545</Color>
    <Color x:Key="NeonCyanColor">#FF00F0FF</Color>
    <Color x:Key="ElectricPurpleColor">#FF8B5CF6</Color>
    <Color x:Key="NeonPinkColor">#FFFF006E</Color>
    <Color x:Key="NeonGreenColor">#FF00FF88</Color>
    <Color x:Key="TextPrimaryColor">#FFE0E0FF</Color>
    <Color x:Key="TextSecondaryColor">#FF8888AA</Color>
    <Color x:Key="TextMutedColor">#FF555577</Color>
    <Color x:Key="DangerColor">#FFFF4444</Color>
    <Color x:Key="SuccessColor">#FF00FF88</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="DeepSpaceBrush" Color="{StaticResource DeepSpaceColor}"/>
    <SolidColorBrush x:Key="DarkPanelBrush" Color="{StaticResource DarkPanelColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="NeonCyanBrush" Color="{StaticResource NeonCyanColor}"/>
    <SolidColorBrush x:Key="ElectricPurpleBrush" Color="{StaticResource ElectricPurpleColor}"/>
    <SolidColorBrush x:Key="NeonPinkBrush" Color="{StaticResource NeonPinkColor}"/>
    <SolidColorBrush x:Key="NeonGreenBrush" Color="{StaticResource NeonGreenColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="CyanPurpleGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource NeonCyanColor}" Offset="0"/>
        <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PurplePinkGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="0"/>
        <GradientStop Color="{StaticResource NeonPinkColor}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF0D0D22" Offset="0"/>
        <GradientStop Color="#FF080818" Offset="1"/>
    </LinearGradientBrush>

    <!-- Glow Effects -->
    <DropShadowEffect x:Key="CyanGlow" Color="{StaticResource NeonCyanColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
    <DropShadowEffect x:Key="PurpleGlow" Color="{StaticResource ElectricPurpleColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
    <DropShadowEffect x:Key="PinkGlow" Color="{StaticResource NeonPinkColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.6"/>
    <DropShadowEffect x:Key="SubtleGlow" Color="{StaticResource NeonCyanColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>

    <!-- Fonts -->
    <FontFamily x:Key="MainFont">Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>

    <!-- Nav Button Style -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="8" Margin="6,2" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource NeonCyanBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Active Nav Button -->
    <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
        <Setter Property="Foreground" Value="{StaticResource NeonCyanBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8" Margin="6,2" Padding="{TemplateBinding Padding}"
                            BorderBrush="{StaticResource NeonCyanBrush}" BorderThickness="0,0,0,0">
                        <Grid>
                            <Rectangle Width="3" HorizontalAlignment="Left" Margin="-10,0,0,0"
                                       RadiusX="1.5" RadiusY="1.5">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="{StaticResource NeonCyanColor}" Offset="0"/>
                                        <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Neon Button Style -->
    <Style x:Key="NeonButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource NeonCyanBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource SubtleGlow}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource NeonCyanColor}" Opacity="0.15"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Bd" Property="Effect" Value="{StaticResource CyanGlow}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource NeonCyanColor}" Opacity="0.25"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filled Neon Button -->
    <Style x:Key="NeonButtonFilled" TargetType="Button" BasedOn="{StaticResource NeonButton}">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource NeonCyanColor}" Offset="0"/>
                    <GradientStop Color="{StaticResource ElectricPurpleColor}" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="#FF0B0B1A"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Card Panel Style -->
    <Style x:Key="CardPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DarkPanelBrush}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="{StaticResource NeonCyanColor}" Opacity="0.1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Stat Text Styles -->
    <Style x:Key="StatNumber" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
    </Style>

    <Style x:Key="StatLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <!-- Text is already uppercase in XAML content -->
    </Style>

    <!-- ScrollBar Style -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- TextBox Style -->
    <Style x:Key="NeonTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="CaretBrush" Value="{StaticResource NeonCyanBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource ElectricPurpleBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource NeonCyanBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Default ComboBox styling so dropdown items are readable on the
         dark cyberpunk theme (white-on-white was unreadable). -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource DarkPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource DarkPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource NeonCyanBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
